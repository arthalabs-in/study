App.theme-retro #cmd-suggest > .option-list--option { color: #ebdbb2; }
App.theme-retro #cmd-suggest > .option-list--option-highlighted { background: #d79921 20%; color: #d79921; }
App.theme-retro #chat-input {
    background: #1d2021;
    color: #ebdbb2;
    border: double #504945;
    margin: 0 0 1 0;
}
App.theme-retro #chat-input:focus { border: double #d79921; }
App.theme-retro #chat-input .input--placeholder { color: #504945; }
App.theme-retro #typing-indicator { background: #282828; color: #cc241d; }


/* ═══════════════════════════════════════════════════════
