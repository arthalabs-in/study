/* ═══════════════════════════════════════════════════════
   THEME 6: PAPER
   Soft bright reading theme with ink-like accents.
   ═══════════════════════════════════════════════════════ */

App.theme-paper Screen { background: #f5f1e8; color: #55493d; }
App.theme-paper Header { background: #ebe3d6; color: #8e7f6f; border-bottom: solid #d8c7b2; }

