App.theme-paper 
App.theme-paper HeaderTitle { color: #b06b2d; text-style: bold; }
App.theme-paper Footer { background: #ebe3d6; color: #8e7f6f; border-top: solid #d8c7b2; }
App.theme-paper FooterKey { background: #ebe3d6; color: #8e7f6f; }
